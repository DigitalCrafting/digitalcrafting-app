{
  "name": "@zoria-ui/styles",
  "version": "0.1.1",
  "description": "A modular UI library styles for personal projects (Work in Progress).",
  "private": false,
  "main": "src/index.css",
  "style": "src/index.css",
  "scripts": {
    "build": "sass src/index.scss dist/index.css --style=compressed"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "main": "./dist/index.css",
    "style": "./dist/index.css",
    "exports": {
      ".": "./dist/index.css",
      "./scss": "./src/index.scss"
    }
  },
  "keywords": [
    "zoria",
    "zoria-ui",
    "css",
    "scss",
    "sass",
    "styles",
    "design-system",
    "theme",
    "variables",
    "flexbox",
    "grid",
    "ui-library"
  ],
  "author": "Kamil Kasprzyk (DigitalCrafting) (https://digitalcrafting.dev)",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "sass": "^1.97.3"
  }
}
