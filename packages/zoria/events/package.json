{
  "name": "@zoria-ui/events",
  "private": false,
  "version": "0.2.1",
  "description": "A from scratch events library for personal projects (Work in Progress).",
  "repository": {
    "url": "https://github.com/DigitalCrafting/digitalcrafting-app/tree/master/packages/zoria/events"
  },
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "vite",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "zoria",
    "zoria-ui",
    "events",
    "event-emitter",
    "ee",
    "pubsub",
    "observer",
    "custom-events",
    "typescript",
    "pub-sub"
  ],
  "author": "Kamil Kasprzyk (DigitalCrafting) (https://digitalcrafting.dev)",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1"
}
